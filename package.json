{
  "name": "yt-player",
  "description": "A friendly wrapper around the YouTube Iframe API.",
  "keywords": [
    "yt",
    "player",
    "a",
    "friendly",
    "wrapper",
    "around",
    "the",
    "youtube",
    "iframe",
    "api"
  ],
  "license": "MIT",
  "version": "1.0.0",
  "main": "lib/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "rls": "npm run dev-release && babel dist/yt-player.min.js -o dist/yt-player.min.js",
    "release": "npm run dev-release && babel dist/yt-player.min.js | uglifyjs -c -m -o dist/yt-player.min.js",
    "dev-release": "browserify lib/index.js -o dist/yt-player.min.js -s YTPlayer",
    "build": "esbuild lib/index.js --bundle --minify --sourcemap --outfile=dist/yt-player.min.js --global-name=YTPlayer",
    "dev": "esbuild lib/index.js --bundle --sourcemap --outfile=dist/yt-player.js --global-name=YTPlayer --watch"
  },
  "author": "Ionică Bizău <bizauionica@gmail.com> (http://ionicabizau.net)",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/IonicaBizau/yt-player.git"
  },
  "bugs": {
    "url": "https://github.com/IonicaBizau/yt-player/issues"
  },
  "homepage": "https://github.com/IonicaBizau/yt-player#readme",
  "dependencies": {
    "cb-buffer": "^2.1.0",
    "class-methods": "^2.0.0",
    "function.name": "^1.0.0",
    "iterate-object": "^1.3.2",
    "lc-first": "^1.0.2"
  },
  "devDependencies": {
    "esbuild": "^0.27.4"
  }
}
